# ── 5. CORE ENGINES (FORGETTING CURVE & STREAKS) ──────────────
INTERVALS = [1, 3, 7, 14, 21, 60, 180, 365]

def calculate_stability(record):
    """Calculates memory decay based on Hermann Ebbinghaus's research."""
    if not record.get("last_date"): return 100.0
    last = date.fromisoformat(record["last_date"])
    days_since = (date.today() - last).days
    times = record.get("times_revised", 0)
    decay_rate = 0.5 if times == 0 else 0.3 / (times * 0.5 + 1)
    stability = 100 * (0.5 ** (days_since * decay_rate))
    return max(0.0, min(100.0, stability))

# ── 6. LOGIN & REGISTRATION ──────────────────────────────────
def render_login():
    st.markdown("<div style='margin-top:50px;'><h1 class='qarma-title'>🕌 QARMA</h1></div>", unsafe_allow_html=True)
    tab1, tab2 = st.tabs(["Login", "Create Account"])
    users = load_all_users()

    with tab1:
        u_name = st.text_input("Username", key="l_user")
        u_pass = st.text_input("Password", type="password", key="l_pass")
        if st.button("Sign In"):
            if u_name in users and users[u_name]["password"] == make_hash(u_pass):
                st.session_state.current_user = u_name
                st.session_state.data = users[u_name]["data"]
                st.rerun()
            else:
                st.error("Invalid credentials.")

    with tab2:
        n_name = st.text_input("Choose Username", key="r_user")
        n_pass = st.text_input("Choose Password", type="password", key="r_pass")
        if st.button("Register"):
            if n_name in users: st.error("User exists.")
            elif len(n_name) < 3: st.error("Name too short.")
            else:
                users[n_name] = {
                    "password": make_hash(n_pass),
                    "data": {"name": n_name, "lang": "en", "streak": 0, "points": 0, "surahs": {}, "last_session": None}
                }
                save_all_users(users)
                st.success("Account created! Go to Login tab.")

# ── 7. MAIN APP LOGIC ─────────────────────────────────────────
def init_state():
    if "current_user" not in st.session_state: st.session_state.current_user = None
    if "page" not in st.session_state: st.session_state.page = "dashboard"

def sync_data():
    """Ensures the local session matches the global storage."""
    users = load_all_users()
    users[st.session_state.current_user]["data"] = st.session_state.data
    save_all_users(users)

def main():
    init_state()
    
    if st.session_state.current_user is None:
        render_login()
    else:
        # Sidebar with Logout
        with st.sidebar:
            st.write(f"Logged in as: **{st.session_state.current_user}**")
            if st.button("🚪 Logout"):
                st.session_state.current_user = None
                st.rerun()
            
