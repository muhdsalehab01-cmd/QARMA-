# ── 2. DATA PERSISTENCE & SECURITY ─────────────────────────────
USER_DATA_FILE = "qarma_users.json"

def save_all_users(users_dict):
    """Saves all user data to a local JSON file."""
    with open(USER_DATA_FILE, "w", encoding="utf-8") as f:
        json.dump(users_dict, f)

def load_all_users():
    """Loads all user data from the JSON file if it exists."""
    if os.path.exists(USER_DATA_FILE):
        with open(USER_DATA_FILE, "r", encoding="utf-8") as f:
            return json.load(f)
    return {}

def make_hash(password):
    """Securely hashes passwords so they aren't stored in plain text."""
    return hashlib.sha256(str.encode(password)).hexdigest()

